<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Deniz OFFICIAL</title>
  
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

  <style>
    :root {
      --accent: #00f2ea;
      --pink: #ff0050;
      --snap: #FFFC00;
      --bg: #050505;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

    body {
      background-color: var(--bg);
      color: white;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    .glow-top {
      position: absolute;
      top: -10%;
      width: 100%;
      height: 40%;
      background: radial-gradient(circle, rgba(124, 58, 237, 0.2) 0%, transparent 70%);
      z-index: 0;
    }

    .card {
      position: relative;
      z-index: 10;
      width: 85%;
      max-width: 360px;
      padding: 25px 20px;
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 40px;
      backdrop-filter: blur(25px);
      -webkit-backdrop-filter: blur(25px);
      text-align: center;
      box-shadow: 0 25px 50px rgba(0,0,0,0.5);
    }

    h1 {
      font-size: 4rem;
      font-weight: 900;
      letter-spacing: -3px;
      cursor: pointer;
      background: linear-gradient(to bottom, #fff 30%, #666);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      user-select: none;
      margin-bottom: 5px;
    }

    /* --- Smaller Storm Scene Box --- */
    .storm-scene {
      margin: 10px auto 0;
      width: 75%; /* Narrower for the "small box" look */
      height: 130px; /* Shorter box */
      border-radius: 20px;
      border: 1px solid rgba(255,255,255,0.1);
      position: relative;
      overflow: hidden;
      background: #000;
    }

    .scene-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0.8;
      filter: brightness(0.8) contrast(1.2);
      animation: lightningFlash 8s linear infinite;
    }

    .rain-overlay {
      position: absolute;
      top: 0; left: 0; width: 100%; height: 100%;
      z-index: 2;
      pointer-events: none;
    }

    .rain-overlay::after {
      content: "";
      position: absolute;
      top: -100%;
      left: 0;
      width: 100%;
      height: 200%;
      background-image: repeating-linear-gradient(170deg, 
        transparent 0%, 
        transparent 10%, 
        rgba(255, 255, 255, 0.1) 10%, 
        rgba(255, 255, 255, 0.1) 11%, 
        transparent 11%);
      background-size: 100% 40px;
      animation: rainFall 0.4s linear infinite;
    }

    @keyframes rainFall {
      from { transform: translateY(0); }
      to { transform: translateY(40px); }
    }

    @keyframes lightningFlash {
      0%, 45%, 55%, 100% { filter: brightness(0.8) contrast(1.2); }
      48% { filter: brightness(2.5) contrast(1.5); }
      50% { filter: brightness(1) contrast(1.2); }
      52% { filter: brightness(2) contrast(1.4); }
    }

    /* UI elements */
    .btn {
      position: fixed;
      bottom: 40px;
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 16px 24px;
      border-radius: 25px;
      text-decoration: none;
      font-weight: 800;
      z-index: 20;
      transition: 0.3s;
    }
    
    .tiktok-btn { left: 20px; background: #000; color: white; box-shadow: -4px 0 0 var(--pink), 4px 0 0 var(--accent); }
    .snap-btn { right: 20px; background: var(--snap); color: black; }

    .music-bar {
      position: fixed;
      top: 25px;
      left: 20px;
      display: flex;
      align-items: center;
      gap: 10px;
      z-index: 100;
    }
    .m-btn {
      width: 40px; height: 40px; border-radius: 50%; border: none;
      background: rgba(255,255,255,0.1); color: white; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
    }

    @keyframes rainbow { 0% { filter: hue-rotate(0deg); } 100% { filter: hue-rotate(360deg); } }
    .high-mode { animation: rainbow 4s linear infinite; }
  </style>
</head>
<body id="mainBody">

  <div class="glow-top"></div>

  <div class="music-bar">
    <button class="m-btn" id="playBtn" onclick="togglePlay()"><i class="fa-solid fa-play"></i></button>
    <div style="font-size: 9px; opacity: 0.5; letter-spacing: 1px;" id="songTitle">THE MOON AND THE SKY</div>
  </div>

  <!-- AUDIO PLAYER WITH YOUR LINK -->
  <audio id="audioPlayer" loop>
    <source src="https://files.catbox.moe/xg445g.mp3" type="audio/mpeg">
  </audio>

  <main class="card">
    <p style="font-size: 9px; opacity: 0.4; letter-spacing: 4px; margin-bottom: 5px;">BERO OFFICIAL</p>
    <h1 id="heroName" onclick="handleEgg()">BERO</h1>
    
    <div class="storm-scene">
      <img src="https://files.catbox.moe/vinhxn.webp" class="scene-img" alt="Bero Character">
      <div class="rain-overlay"></div>
    </div>
  </main>

  <a href="https://www.tiktok.com/@denizhavin.dgn" class="btn tiktok-btn" target="_blank">
    <i class="fa-brands fa-tiktok"></i><span>TIKTOK</span>
  </a>

  <a href="https://www.snapchat.com/add/denizhavin01" class="btn snap-btn" target="_blank">
    <i class="fa-brands fa-snapchat"></i><span>SNAP</span>
  </a>

  <script>
    const player = document.getElementById('audioPlayer');
    const btn = document.getElementById('playBtn');

    function togglePlay() {
      if (player.paused) {
        player.play();
        btn.innerHTML = '<i class="fa-solid fa-pause"></i>';
        btn.style.background = "var(--accent)";
      } else {
        player.pause();
        btn.innerHTML = '<i class="fa-solid fa-play"></i>';
        btn.style.background = "rgba(255,255,255,0.1)";
      }
    }

    // This makes the music start as soon as the user clicks anywhere on the page
    document.body.addEventListener('click', function() {
        if (player.paused) {
            togglePlay();
        }
    }, { once: true });

    let taps = 0;
    let timer;
    function handleEgg() {
      taps++;
      clearTimeout(timer);
      if(taps === 5) {
        document.getElementById('mainBody').classList.add('high-mode');
        document.getElementById('heroName').innerText = "HIGH MODE";
        taps = 0;
      }
      timer = setTimeout(() => { taps = 0; }, 2000);
    }
  </script>

</body>
</html>
